(macro (spec X Y) (def X Y))

(def 1 (+nat (s 0)))
(def 2 (+nat (s (s 0))))
(def 3 (+nat (s (s (s 0)))))

(spec nat [(-nat (s X)) (+nat X)])

(def tested @(exec @#1 *#nat))
(== #tested (+nat 0))

(def tested @(exec @#2 *#nat))
(== #tested (+nat (s 0)))

(def tested @(exec @#3 *#nat))
(== #tested (+nat (s (s 0))))
