(macro (spec X Y) (def X Y))

(def 1 (+nat (s 0)))
(def 2 (+nat (s (s 0))))
(def 3 (+nat (s (s (s 0)))))

(spec nat [(-nat (s X)) (+nat X)])

(def tested @(fire @#1 #nat))
(== #tested (+nat 0))

(def tested @(fire @#2 #nat))
(== #tested (+nat (s 0)))

(def tested @(fire @#3 #nat))
(== #tested (+nat (s (s 0))))
