(def left  [(+5 [l l|X]) (+5 [l r|X]) || (slice c a)])
(def right [(+5 [r l|X]) (+5 [r r|X]) || (slice c b)])

(def with { #left #right })

(def plus {
  [(+3 [l l|X]) (c X)]
  [(+3 [l r|X]) (d X)]})

; the cut carries one exchange per address, so it is written split
; address-wise: one reactive star per address
(def cut {
  [(-5 [l l|X]) (-3 [l l|X])]
  [(-5 [l r|X]) (-3 [l r|X])]
  [(-5 [r l|X]) (-3 [r l|X])]
  [(-5 [r r|X]) (-3 [r r|X])]})

(show (then
  #with
  { #plus #cut }))
